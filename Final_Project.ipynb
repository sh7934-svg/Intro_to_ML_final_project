    "def feed_forward(x, W, b):\n",
    "    \"\"\"\n",
    "    Hidden layers: ReLU\n",
    "    Output layer:  Softmax\n",
    "    Returns a (activations) and z (pre-activations) dicts.\n",
    "    \"\"\"\n",
    "    n_layers = len(W)\n",
    "    a = {1: x}\n",
    "    z = {}\n",
    "    for l in range(1, n_layers + 1):\n",
    "        z[l+1] = W[l].dot(a[l]) + b[l]\n",
    "        if l < n_layers:          # hidden layer → ReLU\n",
    "            a[l+1] = relu(z[l+1])\n",
    "        else:                     # output layer → Softmax\n",
    "            a[l+1] = softmax(z[l+1])\n",
    "    return a, z"
