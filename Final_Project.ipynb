    "# One-hot encode targets\n",
    "def to_onehot(y, n_classes=10):\n",
    "    Y = np.zeros((len(y), n_classes))\n",
    "    Y[np.arange(len(y)), y] = 1\n",
    "    return Y\n",
    "\n",
    "y_v_train = to_onehot(y_train)\n",
