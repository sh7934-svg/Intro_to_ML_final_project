    "def relu(z):\n",
    "    \"\"\"ReLU activation: max(0, z)\"\"\"\n",
    "    return np.maximum(0, z)\n",
    "\n",
    "def relu_deriv(z):\n",
    "    \"\"\"Derivative of ReLU\"\"\"\n",
    "    return (z > 0).astype(float)\n",
    "\n",
    "def softmax(z):\n",
    "    \"\"\"Numerically stable softmax\"\"\"\n",
    "    e = np.exp(z - np.max(z))\n",
    "    return e / e.sum()\n",
    "\n",
    "def sigmoid(z):\n",
